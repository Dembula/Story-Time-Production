  @@index([projectId])
  @@index([senderId])
}

model ProjectTask {
  id          String   @id @default(cuid())
  projectId   String
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
