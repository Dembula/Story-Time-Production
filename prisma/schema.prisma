generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Use a non-pooling direct connection for Prisma CLI migrations/DDL.
  // Supabase: Project Settings → Database → Connection string → "Direct".
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// NextAuth email/magic-link verification (required when using PrismaAdapter with EmailProvider).
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("SUBSCRIBER")
  adminRights   Json?     // optional fine-grained admin permissions when assigned
  bio           String?
  socialLinks   String?
  education     String?
  goals         String?
  previousWork  String?
  isAfdaStudent Boolean   @default(false)
  passwordHash String?
  headline      String?   // network profile tagline
  location      String?   // city/region for network
  website       String?   // personal or studio site
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  adminRequestsRequested AdminRequest[] @relation("AdminRequestRequester")
  adminRequestsReviewed  AdminRequest[] @relation("AdminRequestReviewer")
  sessions      Session[]

  watchSessions WatchSession[]
  comments      Comment[]
  ratings       Rating[]
  contents      Content[]
  musicTracks   MusicTrack[]
  watchlist     WatchlistItem[]
  activityLogs  ActivityLog[]
  auditionPosts AuditionPost[]

  equipmentListings      EquipmentListing[]
  equipmentRequests      EquipmentRequest[] @relation("EquipmentRequester")
  equipmentRequestsRecv  EquipmentRequest[] @relation("EquipmentCompany")
  sentMessages           Message[]          @relation("MessageSender")
  receivedMessages       Message[]          @relation("MessageReceiver")
  syncRequestsSent       SyncRequest[]      @relation("SyncRequester")
  syncRequestsRecv       SyncRequest[]      @relation("SyncMusicCreator")

  originalPitches        OriginalPitch[]
  originalMembers        OriginalMember[]
  projectIdeas           ProjectIdea[]

  locationListings       LocationListing[]
  locationBookingsSent    LocationBooking[] @relation("LocationRequester")
  locationBookingsRecv   LocationBooking[]  @relation("LocationOwner")

  crewTeam               CrewTeam?
  castingAgency          CastingAgency?
  cateringCompany        CateringCompany?
  creatorCrewRoster      CreatorCrewRoster[]
  creatorCastRoster      CreatorCastRoster[]
  crewTeamRequestsSent   CrewTeamRequest[]  @relation("CrewTeamRequester")
  castingInquiriesSent   CastingInquiry[]   @relation("CastingInquiryCreator")
  cateringBookingsSent   CateringBooking[]   @relation("CateringRequester")

  viewerSubscriptions    ViewerSubscription[]
  viewerProfiles         ViewerProfile[]
  creatorBanking         CreatorBanking?
  creatorPayouts         CreatorPayout[]    @relation("CreatorPayoutCreator")
  transactionsSent       Transaction[]      @relation("TransactionPayer")
  transactionsReceived   Transaction[]      @relation("TransactionPayee")
  creatorDistributionLicense CreatorDistributionLicense?
  uploadPayments         UploadPayment[]
  creatorVotesSent       CreatorVote[]      @relation("CreatorVoteVoter")
  creatorVotesReceived   CreatorVote[]      @relation("CreatorVoteCreator")
  competitionWins       CompetitionPeriod[] @relation("CompetitionWinner")
  companySubscriptions   CompanySubscription[]
  userPreference        UserPreference?
  viewerPaymentMethods  ViewerPaymentMethod[]

  notifications         Notification[]
  modocConversations   ModocConversation[]

  // Project & production tooling ownership/participation
  projectTasksCreated   ProjectTask[]        @relation("ProjectTaskCreator")
  projectTasksAssigned  ProjectTask[]
  projectScriptVersionsCreated ProjectScriptVersion[]
  projectActivities     ProjectActivity[]
  scriptReviewRequestsRequested ScriptReviewRequest[]
  scriptReviewRequestsReviewed ScriptReviewRequest[] @relation("ScriptReviewReviewer")
  productionExpensesCreated ProductionExpense[]
  projectContractsAsCounterparty ProjectContract[]
  projectContractsCreated ProjectContract[]  @relation("ProjectContractCreator")
  projectContractVersionsCreated ProjectContractVersion[] @relation("ProjectContractVersionCreator")
  projectSignatures     ProjectSignature[]
  pitchDecksCreated     PitchDeck[]
  projectChatThreadsCreated ProjectChatThread[]
  projectChatMessages   ProjectChatMessage[]
  crewInvitationsCreated CrewInvitation[]
  castingInvitationsCreated CastingInvitation[]
  tableReadSessionsCreated TableReadSession[]
  tableReadParticipants TableReadParticipant[]
  tableReadNotes        TableReadNote[]
  riskChecklistItems    RiskChecklistItem[]
  continuityNotes       ContinuityNote[]

  // Network (social / follow, connect, posts, DMs)
  following             CreatorFollow[]    @relation("CreatorFollowing")
  followers             CreatorFollow[]    @relation("CreatorFollower")
  connectionRequestsSent     ConnectionRequest[] @relation("ConnectionRequestFrom")
  connectionRequestsReceived ConnectionRequest[] @relation("ConnectionRequestTo")
  networkPosts          NetworkPost[]
  conversationParticipants NetworkConversationParticipant[]
  networkMessagesSent   NetworkMessage[]
  incidentReports       IncidentReport[]
  dailiesNotes          DailiesNote[]
  reviewNotes           ReviewNote[]
}

model AdminRequest {
  id             String    @id @default(cuid())
  status         String    // PENDING, APPROVED, DENIED
  assignedRights Json?     // e.g. { "canManageUsers": true, "canManageContent": true }
  note           String?   // denial reason
  requestedAt    DateTime  @default(now())
  reviewedAt     DateTime?

  requestedById  String
  requestedBy    User      @relation("AdminRequestRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedById   String?
  reviewedBy     User?     @relation("AdminRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([requestedById])
  @@index([status])
}

model Content {
  id          String      @id @default(cuid())
  title       String
  description String?
  type        String
  posterUrl   String?
  backdropUrl String?
  videoUrl    String?
  trailerUrl  String?
  scriptUrl   String?
  category    String?
  tags        String?
  language    String?
  country     String?
  ageRating   String?
  /// Minimum viewer age required to watch this title (used for profile censorship).
  /// If not set by creator, the platform may derive this from ageRating during ingestion.
  minAge      Int         @default(0)
  /// Structured advisory flags and notes (e.g. { drugs: true, sex: false, violence: true, language: true, nudity: false, selfHarm: false, horror: true, discrimination: false, themes: "..." }).
  advisory    Json?
  year        Int?
  duration    Int?
  episodes    Int?
  featured    Boolean     @default(false)
  published   Boolean     @default(true)
  reviewStatus String    @default("DRAFT")
  reviewNote   String?
  submittedAt  DateTime?
  reviewedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  creatorId   String
  creator     User        @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  btsVideos     BtsVideo[]
  watchSessions WatchSession[]
  comments      Comment[]
  ratings       Rating[]
  watchlist     WatchlistItem[]
  syncDeals     SyncDeal[]
  crewMembers   CrewMember[]
  auditionPosts AuditionPost[]
  networkPosts  NetworkPost[]
}

model BtsVideo {
  id        String   @id @default(cuid())
  title     String
  videoUrl  String?
  thumbnail String?
  sortOrder Int       @default(0)
  createdAt DateTime @default(now())

  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model WatchSession {
  id               String   @id @default(cuid())
  durationSeconds  Int
  startedAt        DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  viewerProfileId String?
  viewerProfile   ViewerProfile? @relation(fields: [viewerProfileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([contentId])
  @@index([startedAt])
  @@index([viewerProfileId])
}

/// Viewer sub-accounts under a single subscriber login (per-device profiles).
model ViewerProfile {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  age       Int
  /// Free-form personalization and learned preferences for recommendations.
  preferences Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  watchSessions WatchSession[]

  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  parentId  String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")
}

model Rating {
  id        String   @id @default(cuid())
  score     Int
  createdAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([contentId])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model MusicTrack {
  id           String   @id @default(cuid())
  title        String
  artistName   String
  audioUrl     String?
  coverUrl     String?
  genre        String?
  mood         String?
  bpm          Int?
  key          String?
  duration     Int?
  description  String?
  tags         String?
  isrc         String?
  language     String?
  published    Boolean  @default(true)
  licenseType  String   @default("SYNC")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creatorId    String
  creator      User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  syncDeals    SyncDeal[]
  syncRequests SyncRequest[]
  musicSelections MusicSelection[]
}

model SyncDeal {
  id        String   @id @default(cuid())
  amount    Float    @default(0)
  status    String
  createdAt DateTime @default(now())

  contentId   String
  content     Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  musicTrackId String
  musicTrack  MusicTrack @relation(fields: [musicTrackId], references: [id], onDelete: Cascade)

  @@unique([contentId, musicTrackId])
}

model PlatformRevenue {
  id        String   @id @default(cuid())
  period    String
  amount    Float
  createdAt DateTime @default(now())
}

model PendingCreatorSignup {
  id              String   @id @default(cuid())
  email           String   @unique
  type            String
  bio             String?
  socialLinks     String?
  education       String?
  goals           String?
  previousWork    String?
  isAfdaStudent   Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  userEmail  String?
  userName   String?
  role       String
  eventType  String
  referrer   String?
  userAgent  String?
  ipAddress  String?
  deviceType String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([role])
}

model EquipmentListing {
  id          String   @id @default(cuid())
  companyName String
  description String?
  category    String
  imageUrl    String?
  contactUrl  String?
  location    String?
  createdAt   DateTime @default(now())

  companyId   String?
  company     User?    @relation(fields: [companyId], references: [id], onDelete: SetNull)

  requests    EquipmentRequest[]

  planItems   EquipmentPlanItem[]

  @@index([companyId])
}

model EquipmentRequest {
  id          String   @id @default(cuid())
  status      String   @default("PENDING")
  note        String?
  startDate   String?
  endDate     String?
  paymentTransactionId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  equipmentId String
  equipment   EquipmentListing @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  requesterId String
  requester   User   @relation("EquipmentRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  companyId   String
  company     User   @relation("EquipmentCompany", fields: [companyId], references: [id], onDelete: Cascade)

  messages    Message[]

  @@index([requesterId])
  @@index([companyId])
  @@index([equipmentId])
}

model Message {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  senderId   String
  sender     User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId String
  receiver   User   @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  requestId      String?
  request        EquipmentRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)

  syncRequestId  String?
  syncRequest    SyncRequest? @relation(fields: [syncRequestId], references: [id], onDelete: Cascade)

  locationBookingId  String?
  locationBooking    LocationBooking? @relation(fields: [locationBookingId], references: [id], onDelete: Cascade)

  crewTeamRequestId  String?
  crewTeamRequest    CrewTeamRequest? @relation(fields: [crewTeamRequestId], references: [id], onDelete: Cascade)

  castingInquiryId   String?
  castingInquiry     CastingInquiry? @relation(fields: [castingInquiryId], references: [id], onDelete: Cascade)

  cateringBookingId  String?
  cateringBooking    CateringBooking? @relation(fields: [cateringBookingId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([requestId])
  @@index([syncRequestId])
  @@index([locationBookingId])
  @@index([crewTeamRequestId])
  @@index([castingInquiryId])
  @@index([cateringBookingId])
}

model SyncRequest {
  id          String   @id @default(cuid())
  status      String   @default("PENDING")
  note        String?
  projectName String?
  projectType String?
  usageType   String?
  budget      Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trackId     String
  track       MusicTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  requesterId String
  requester   User   @relation("SyncRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  musicCreatorId String
  musicCreator   User @relation("SyncMusicCreator", fields: [musicCreatorId], references: [id], onDelete: Cascade)

  messages    Message[]

  @@index([trackId])
  @@index([requesterId])
  @@index([musicCreatorId])
}

model CrewMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String?
  createdAt DateTime @default(now())

  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

model AuditionPost {
  id          String   @id @default(cuid())
  roleName    String
  description String?
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())

  contentId String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  creatorId String
  creator   User    @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([creatorId])
}

model OriginalProject {
  id            String   @id @default(cuid())
  title         String
  logline       String?
  synopsis      String?
  type          String
  genre         String?
  status        String   @default("DEVELOPMENT")
  phase         String   @default("CONCEPT")
  budget        Float?
  targetDate    String?
  posterUrl     String?
  adminNote     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pitches       OriginalPitch[]
  members       OriginalMember[]
  networkPosts  NetworkPost[]
  ideas         ProjectIdea[]
  workspaceLinks ProjectWorkspaceLink[]
  toolProgress  ProjectToolProgress[]
  distributionSubmissions DistributionSubmission[]
  finalDeliveries FinalDelivery[]
  postProductionReviews PostProductionReview[]
  musicSelections MusicSelection[]
  footageAssets FootageAsset[]
  incidentReports IncidentReport[]

  // Pre-production & production tooling
  scripts       ProjectScript[]
  scenes       ProjectScene[]
  projectActivities ProjectActivity[]
  scriptReviewRequests ScriptReviewRequest[]
  breakdownCharacters BreakdownCharacter[]
  breakdownProps BreakdownProp[]
  breakdownLocations BreakdownLocation[]
  breakdownWardrobes BreakdownWardrobe[]
  breakdownExtras BreakdownExtra[]
  breakdownVehicles BreakdownVehicle[]
  breakdownStunts BreakdownStunt[]
  breakdownSfxs BreakdownSfx[]
  projectBudget ProjectBudget?
  productionExpenses ProductionExpense[]
  shootDays     ShootDay[]
  callSheets    CallSheet[]
  castingRoles CastingRole[]
  castingInvitations CastingInvitation[]
  crewRoleNeeds CrewRoleNeed[]
  crewInvitations CrewInvitation[]
  projectContracts ProjectContract[]
  fundingRequest FundingRequest?
  pitchDeck     PitchDeck?
  chatThreads   ProjectChatThread[]
  chatMessages  ProjectChatMessage[]
  projectTasks   ProjectTask[]
  tableReadSessions TableReadSession[]
  equipmentPlanItems EquipmentPlanItem[]
  riskPlan      RiskPlan?
  continuityNotes ContinuityNote[]
  dailiesBatches DailiesBatch[]

  @@index([status])
}

model OriginalPitch {
  id                String   @id @default(cuid())
  title             String
  logline           String?
  synopsis          String?
  type              String
  genre             String?
  scriptUrl         String?   // PDF upload URL or external link
  scriptProjectId   String?   // deprecated: use scriptId; kept for backward compat
  scriptId          String?   // ProjectScript id when attached from Pre-Production Script Writing
  treatmentUrl      String?
  lookbookUrl       String?
  budgetEst         Float?
  targetAudience   String?
  references        String?
  directorStatement String?
  productionCompany String?
  previousWorkSummary String?
  intendedRelease   String?
  keyCastCrew       String?
  financingStatus  String?
  status            String   @default("SUBMITTED")
  adminNote         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  creatorId     String
  creator       User    @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  projectId     String?
  project       OriginalProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([creatorId])
  @@index([status])
  @@index([projectId])
}

model OriginalMember {
  id         String   @id @default(cuid())
  role       String
  department String?
  status     String   @default("INVITED")
  note       String?
  createdAt  DateTime @default(now())

  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId  String
  project    OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@unique([userId, projectId])
}

model LocationListing {
  id           String   @id @default(cuid())
  name         String
  description  String?
  type         String
  address      String?
  city         String?
  province     String?
  country      String?
  capacity     Int?
  dailyRate    Float?
  amenities    String?
  photoUrls    String?
  rules        String?
  availability String?
  contactUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId    String?
  company      User?    @relation(fields: [companyId], references: [id], onDelete: SetNull)

  bookings     LocationBooking[]
  breakdownLocations BreakdownLocation[]
  projectContracts ProjectContract[]

  @@index([companyId])
  @@index([type])
  @@index([city])
}

model LocationBooking {
  id         String   @id @default(cuid())
  status     String   @default("PENDING")
  note       String?
  shootType  String?
  startDate  String?
  endDate   String?
  crewSize   Int?
  paymentTransactionId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  locationId String
  location   LocationListing @relation(fields: [locationId], references: [id], onDelete: Cascade)

  requesterId String
  requester   User   @relation("LocationRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  ownerId    String
  owner      User    @relation("LocationOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  messages   Message[]

  @@index([locationId])
  @@index([requesterId])
  @@index([ownerId])
}

// --- Crew & Cast / Auditions ---

model CrewTeam {
  id              String   @id @default(cuid())
  companyName     String
  tagline         String?
  description     String?
  location        String?
  city            String?
  province        String?
  country         String?
  specializations String?   // comma or JSON: Camera, Grip, Sound, etc.
  website         String?
  contactEmail    String?
  logoUrl         String?
  pastWorkSummary String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  members         CrewTeamMember[]
  requests        CrewTeamRequest[]
  crewInvitations CrewInvitation[]
  projectContracts ProjectContract[]

  @@index([userId])
  @@index([city])
  @@index([country])
}

model CrewTeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String   // e.g. DP, Gaffer, Sound Mixer
  department  String?  // Camera, Grip, Sound, Art, etc.
  bio         String?
  skills      String?
  pastWork    String?
  photoUrl    String?
  email       String?
  phone       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  crewTeamId  String
  crewTeam    CrewTeam @relation(fields: [crewTeamId], references: [id], onDelete: Cascade)

  crewInvitations CrewInvitation[]

  @@index([crewTeamId])
}

model CreatorCrewRoster {
  id            String   @id @default(cuid())
  name          String
  role          String?
  department    String?
  contactEmail   String?
  phone         String?
  notes         String?
  pastProjects  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creatorId     String
  creator       User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
}

model CreatorCastRoster {
  id          String   @id @default(cuid())
  name        String
  roleType    String?  // Actor, Voice, etc.
  contactEmail String?
  notes       String?
  pastWork    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creatorId   String
  creator    User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
}

model CrewTeamRequest {
  id          String   @id @default(cuid())
  projectName String?
  message     String?
  status      String   @default("PENDING") // PENDING, ACCEPTED, DECLINED
  paymentTransactionId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creatorId   String
  creator    User     @relation("CrewTeamRequester", fields: [creatorId], references: [id], onDelete: Cascade)
  crewTeamId String
  crewTeam   CrewTeam @relation(fields: [crewTeamId], references: [id], onDelete: Cascade)

  messages   Message[]

  @@index([creatorId])
  @@index([crewTeamId])
}

model CastingAgency {
  id           String   @id @default(cuid())
  agencyName   String
  tagline      String?
  description  String?
  location     String?
  city         String?
  country      String?
  website      String?
  contactEmail String?
  logoUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  talent       CastingTalent[]
  inquiries    CastingInquiry[]
  castingInvitations CastingInvitation[]

  @@index([userId])
  @@index([city])
  @@index([country])
}

model CastingTalent {
  id          String   @id @default(cuid())
  name        String
  bio         String?
