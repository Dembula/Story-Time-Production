// --- Collaboration: chat, tasks, table reads ---

model ProjectChatThread {
  id          String   @id @default(cuid())
  projectId   String
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String?
  channel     String?  // GENERAL, PRODUCING, CAMERA, etc.
