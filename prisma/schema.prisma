  createdBy   User?   @relation("ProjectContractVersionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  signatures  ProjectSignature[]

  @@index([contractId])
}

model ProjectSignature {
  id          String   @id @default(cuid())
  contractId  String
  contract    ProjectContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  versionId   String
  version     ProjectContractVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String?
  role        String?
  signedAt    DateTime @default(now())
  ipAddress   String?

  @@index([contractId])
  @@index([versionId])
  @@index([userId])
}

// --- Funding & pitch decks ---

model FundingRequest {
  id          String   @id @default(cuid())
  projectId   String   @unique
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  option      String   // HAS_FUNDING or REQUEST_FUNDING
  amount      Float?
  currency    String?  @default("ZAR")
  details     String?
  status      String   @default("PENDING")
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model PitchDeck {
  id          String   @id @default(cuid())
  projectId   String   @unique
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template    String   // SHORT_FILM, FEATURE, etc.
  title       String?
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
