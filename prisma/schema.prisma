// --- Test payments (mock gateway) ---
model TestPayment {
  id        String   @id @default(cuid())
  amount    Float
  currency  String   @default("ZAR")
  status    String   @default("PENDING") // PENDING, COMPLETED, FAILED
  metadata  String?  // JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- User preferences (theme, etc.) ---
model UserPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme           String?  @default("dark") // dark, light, auto
  accentColor     String?
  notifyEmail     Boolean  @default(true)
  playbackQuality String?  // e.g. auto, 1080p, 720p
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model ViewerPaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String   // e.g. "Visa ****4242"
  lastFour  String   // last 4 digits for display
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// --- Social & notifications ---

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // SYSTEM_RELEASE, COLLAB_REQUEST, CONTRACT_EVENT, BOOKING_UPDATE, WEEKLY_HIGHLIGHTS, etc.
  title     String
  body      String
  metadata  String?  // JSON payload for deep-link context
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// --- Creator Network (social: follow, connect, posts, DMs) ---

model CreatorFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("CreatorFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("CreatorFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model ConnectionRequest {
  id        String    @id @default(cuid())
  fromId    String
  toId      String
  status    String    @default("PENDING") // PENDING, ACCEPTED, DECLINED
  message   String?
  createdAt DateTime  @default(now())
  respondedAt DateTime?

  from User @relation("ConnectionRequestFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("ConnectionRequestTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@index([fromId])
  @@index([toId])
  @@index([status])
}

model NetworkPost {
  id         String   @id @default(cuid())
  authorId   String
  body       String?  // text content
  imageUrls  String?  // JSON array of image URLs
  contentId  String?  // optional link to a movie/content
  projectId  String?  // optional link to a project
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author  User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content Content? @relation(fields: [contentId], references: [id], onDelete: SetNull)
  project OriginalProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([authorId])
  @@index([createdAt])
  @@index([contentId])
  @@index([projectId])
}

model NetworkConversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants NetworkConversationParticipant[]
  messages     NetworkMessage[]
}

model NetworkConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  conversation NetworkConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

model NetworkMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime @default(now())

  conversation NetworkConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                 @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

// --- Project pipeline extensions (Creator Dashboard) ---

model ProjectIdea {
  id          String   @id @default(cuid())
  /// Optional link to a specific project. When null, this is a standalone idea in the creator’s vault.
  projectId   String?
  project     OriginalProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  /// Optional owner so standalone ideas can be scoped per creator.
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  title       String
  logline     String?
  notes       String?
  genres      String?  // comma-separated for now
  moodboardUrls String?
  convertedToProject Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

model ProjectScript {
  id          String   @id @default(cuid())
  projectId   String
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  currentVersionId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions    ProjectScriptVersion[]
  scenes      ProjectScene[]

  @@index([projectId])
}

model ProjectScriptVersion {
  id          String   @id @default(cuid())
  scriptId    String
  script      ProjectScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  versionLabel String?
  content     String   // screenplay text
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  autoSavedAt DateTime?

  tableReadSessions TableReadSession[]
  scriptReviewRequests ScriptReviewRequest[]

  @@index([scriptId])
  @@index([createdById])
}

model ProjectScene {
  id          String   @id @default(cuid())
  projectId   String
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scriptId    String?
  script      ProjectScript? @relation(fields: [scriptId], references: [id], onDelete: SetNull)
  number      String   // e.g. "1", "2A"
  heading     String?  // e.g. INT. HOUSE - DAY
  summary     String?
  pageCount   Float?
  status      String   @default("PLANNED") // PLANNED, SCHEDULED, SHOOTING, WRAPPED
  primaryLocationId String?  @unique
  primaryLocation   BreakdownLocation? @relation("PrimaryLocation", fields: [primaryLocationId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  breakdownCharacters BreakdownCharacter[]
  breakdownProps      BreakdownProp[]
  breakdownLocations  BreakdownLocation[] @relation("SceneBreakdown")
  breakdownWardrobes  BreakdownWardrobe[]
  breakdownExtras     BreakdownExtra[]
  breakdownVehicles   BreakdownVehicle[]
  breakdownStunts     BreakdownStunt[]
  breakdownSfxs       BreakdownSfx[]
  shootDayLinks ShootDayScene[]
  continuityNotes ContinuityNote[]
  dailies      DailiesBatch[]
  footageAssets FootageAsset[]

  @@index([projectId])
  @@index([scriptId])
}

model ProjectActivity {
  id          String   @id @default(cuid())
  projectId   String
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type        String   // SCRIPT_UPDATED, BUDGET_UPDATED, CONTRACT_SENT, etc.
  message     String
  metadata    String?  // JSON
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
}

// --- Script review ---

model ScriptReviewRequest {
  id          String   @id @default(cuid())
  projectId   String
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scriptVersionId String?
  scriptVersion   ProjectScriptVersion? @relation(fields: [scriptVersionId], references: [id], onDelete: SetNull)
  requesterId String
  requester   User    @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  reviewerId  String?
  reviewer    User?   @relation("ScriptReviewReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  status      String   @default("PENDING_ADMIN_REVIEW") // PENDING_ADMIN_REVIEW, IN_REVIEW, COMPLETED
  feeAmount   Float    @default(0)
  paymentId   String?  // links to TestPayment.id
  feedbackUrl String?
  feedbackNotes String?
  submittedAt DateTime @default(now())
  reviewedAt  DateTime?

  @@index([projectId])
  @@index([requesterId])
  @@index([reviewerId])
  @@index([status])
}

