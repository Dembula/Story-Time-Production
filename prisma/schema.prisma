model ProjectContract {
  id          String   @id @default(cuid())
  projectId   String
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String   // ACTOR, CREW, LOCATION, VENDOR
  status      String   @default("DRAFT")
  currentVersionId String?
  counterpartyUserId String?
  counterpartyUser   User? @relation(fields: [counterpartyUserId], references: [id], onDelete: SetNull)
  castingTalentId String?
  castingTalent   CastingTalent? @relation(fields: [castingTalentId], references: [id], onDelete: SetNull)
  crewTeamId   String?
  crewTeam     CrewTeam? @relation(fields: [crewTeamId], references: [id], onDelete: SetNull)
