// --- Post-production assets & review ---

model FootageAsset {
  id          String   @id @default(cuid())
  projectId   String
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sceneId     String?
  scene       ProjectScene? @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  type        String   // RAW_FOOTAGE, EDIT, TRAILER, BTS, POSTER, SUBTITLES, MASTER
  label       String?
  fileUrl     String
  metadata    String?  // JSON
  createdAt   DateTime @default(now())

  finalDelivery FinalDelivery?
  postProductionReviews PostProductionReview[]

  @@index([projectId])
  @@index([sceneId])
  @@index([type])
}

model MusicSelection {
  id          String   @id @default(cuid())
  projectId   String
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  trackId     String
  track       MusicTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  usage       String?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([trackId])
}

model PostProductionReview {
  id          String   @id @default(cuid())
  projectId   String
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cutAssetId  String?
  cutAsset    FootageAsset? @relation(fields: [cutAssetId], references: [id], onDelete: SetNull)
  status      String   @default("IN_REVIEW")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  notes       ReviewNote[]

  @@index([projectId])
}

model ReviewNote {
  id          String   @id @default(cuid())
  reviewId    String
  review      PostProductionReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  body        String
  timestampMs Int?
  createdAt   DateTime @default(now())

  @@index([reviewId])
  @@index([userId])
}

model FinalDelivery {
  id          String   @id @default(cuid())
  projectId   String   @unique
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  masterAssetId String? @unique
  masterAsset FootageAsset? @relation(fields: [masterAssetId], references: [id], onDelete: SetNull)
  notes       String?
  status      String   @default("PENDING") // PENDING, SUBMITTED, APPROVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DistributionSubmission {
  id          String   @id @default(cuid())
  projectId   String
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  target      String   // STORY_TIME, NETFLIX, FESTIVAL, etc.
  territories String?
  rights      String?
  status      String   @default("PENDING")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([target])
  @@index([status])
}

/// Workspace link for a project, used to generate a stable, trackable URL per project.
model ProjectWorkspaceLink {
  id           String   @id @default(cuid())
  projectId    String   @unique
  project      OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slug         String   @unique // short public-facing slug, e.g. used in /p/[slug]
  secretToken  String?         // optional extra token for private links if needed
  visitCount   Int      @default(0)
  lastVisitedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId])
  @@index([slug])
}

/// Normalized progress snapshot per tool within a project.
model ProjectToolProgress {
  id          String   @id @default(cuid())
  projectId   String
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase       String   // PRE_PRODUCTION, PRODUCTION, POST_PRODUCTION
  toolId      String   // matches ids from the tool registry, e.g. idea-development
  status      String   @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETE
  percent     Int      @default(0)
  pipelineStep String? // optional high-level step label for rollups
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([projectId, toolId])
  @@index([projectId])
  @@index([phase])
}

// --- MODOC (AI assistant) conversation persistence ---
/// One MODOC chat session (creator, viewer, admin, or company user). Enables resume and history.
model ModocConversation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope       String?  // browse, creator, admin, etc.
  pageContext Json?    // e.g. { projectId, tool, task }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages ModocMessage[]

  @@index([userId])
  @@index([createdAt])
}

/// Single message in a MODOC conversation (user or assistant).
model ModocMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   ModocConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String   // user, assistant, system
  content        String   @db.Text
  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@index([createdAt])
}



