// --- Viewer subscriptions & payments ---
model ViewerSubscription {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                String    // BASE_1, STANDARD_3, FAMILY_5
  status              String    // TRIAL_ACTIVE, ACTIVE, PAST_DUE, CANCELLED
  trialEndsAt         DateTime?
  currentPeriodEnd    DateTime?
  deviceCount         Int       @default(1)
  externalPaymentId   String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  payments            SubscriptionPayment[]

  @@index([userId])
}

model SubscriptionPayment {
  id                    String    @id @default(cuid())
  viewerSubscriptionId  String
  viewerSubscription    ViewerSubscription @relation(fields: [viewerSubscriptionId], references: [id], onDelete: Cascade)
  amount                Float     // in ZAR
  currency              String    @default("ZAR")
  status                String    // PENDING, COMPLETED, FAILED, REFUNDED
  paidAt                DateTime?
  externalPaymentId     String?
  createdAt             DateTime  @default(now())

  @@index([viewerSubscriptionId])
}

model CreatorPayout {
  id          String    @id @default(cuid())
  creatorId   String
  creator     User      @relation("CreatorPayoutCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  amount      Float
  currency    String    @default("ZAR")
  status      String    // PENDING, COMPLETED, FAILED
  bankReference String?
  paidAt      DateTime?
  period      String    // e.g. "2026-01"
  createdAt   DateTime  @default(now())

  @@index([creatorId])
}

model CreatorBanking {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankName      String
  accountNumber String
  accountType   String    // CHEQUE, SAVINGS
  branchCode    String?
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

model Transaction {
  id                String    @id @default(cuid())
  payerId           String
  payer             User      @relation("TransactionPayer", fields: [payerId], references: [id], onDelete: Cascade)
  payeeId           String
  payee             User      @relation("TransactionPayee", fields: [payeeId], references: [id], onDelete: Cascade)
  amount            Float     // base amount in ZAR
  feeAmount         Float     @default(0) // 3% in ZAR
  totalAmount       Float     // amount + feeAmount
  status            String    // PENDING, COMPLETED, FAILED, REFUNDED
  type              String    // LOCATION_BOOKING, EQUIPMENT_REQUEST, CREW_REQUEST, CAST_INQUIRY, CATERING_BOOKING
  referenceId       String    // booking/request/inquiry id
  externalPaymentId String?
  createdAt         DateTime  @default(now())

  @@index([payerId])
  @@index([payeeId])
  @@index([referenceId])
}

// --- Catering ---
model CateringCompany {
