  assignee    User?    @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?    @relation("ProjectTaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([assigneeId])
  @@index([department])
}

model TableReadSession {
  id          String   @id @default(cuid())
  projectId   String
  project     OriginalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
