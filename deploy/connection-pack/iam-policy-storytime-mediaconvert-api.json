{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "MediaConvertJobs",
      "Effect": "Allow",
      "Action": [
        "mediaconvert:CreateJob",
        "mediaconvert:GetJob",
        "mediaconvert:DescribeEndpoints",
        "mediaconvert:ListJobs",
        "mediaconvert:GetQueue",
        "mediaconvert:ListQueues"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PassMediaConvertRole",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::YOUR_ACCOUNT_ID:role/StorytimeMediaConvertRole",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "mediaconvert.amazonaws.com"
        }
      }
    },
    {
      "Sid": "ReadMezzanineForStreamIngest",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:HeadObject"],
      "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME/mezzanine/*"
    }
  ]
}
