{
  "name": "storytime",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "node scripts/dev.mjs",
    "dev:clean": "node scripts/clean-dev-cache.mjs && node scripts/dev.mjs",
    "build": "node scripts/migrate-deploy.mjs && node --max-old-space-size=8192 ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run lint && npm run test:unit",
    "test:unit": "tsx --test src/lib/financial-ledger.test.ts src/lib/creator-team-invites.test.ts src/lib/browse-search.test.ts src/lib/ai-metadata/embeddings.test.ts src/lib/playback-manifest-rewrite.test.ts src/lib/payments/payfast-settlement.test.ts src/lib/payments/sync-licensing-settlement.test.ts src/lib/rate-limit.test.ts src/lib/ai-os/planner/intent-router.test.ts src/lib/modoc/intent-classifier.test.ts src/lib/production-day-engine.unit.test.ts src/lib/ai-os/memory/format-prompt.test.ts src/lib/ai-os/rag/format-prompt.test.ts src/lib/ai-os/knowledge-graph/utils.test.ts src/lib/ai-os/languages/detect.test.ts src/lib/modoc/task-kind.test.ts src/lib/modoc/openrouter-models.test.ts",
    "test:studio-invites": "tsx scripts/test-studio-team-invites.ts",
    "verify": "npm run typecheck && npm run lint",
    "health:platform": "tsx scripts/platform-health-check.ts",
    "payments:smoke:production": "tsx scripts/payfast-production-smoke.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:load:tools": "tsx scripts/load-test-tool-pages.ts",
    "stream:verify": "tsx scripts/verify-cloudflare-setup.ts",
    "stream:require-signed": "tsx scripts/enable-stream-require-signed-urls.ts",
    "content:enrich-backfill": "tsx scripts/backfill-content-enrichment.ts",
    "rag:backfill": "tsx scripts/backfill-knowledge-chunks.ts",
    "graph:backfill": "tsx scripts/backfill-knowledge-graph.ts",
    "languages:seed-glossary": "tsx scripts/seed-sa-language-glossary.ts",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:verify": "tsx scripts/verify-db-tables.ts",
    "quality:gates": "node scripts/quality-gates.mjs",
    "quality:gates:phase2": "set QUALITY_GATE_PHASE=2&& node scripts/quality-gates.mjs",
    "quality:gates:phase3": "set QUALITY_GATE_PHASE=3&& node scripts/quality-gates.mjs",
    "ci": "npm run typecheck && npm run build && npm run test:unit && npm run quality:gates",
    "test:smoke": "node scripts/smoke-dev.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:backfill:kyc-docs": "tsx scripts/backfill-kyc-private-refs.ts",
    "db:backfill:wallets": "tsx scripts/backfill-wallets.ts",
    "payments:reconcile": "tsx scripts/reconcile-ledger.ts",
    "payments:creator-pool:distribute": "tsx scripts/run-creator-pool-distribution.ts",
    "db:studio": "prisma studio",
    "refresh": "prisma generate && node scripts/clear-dev-cache.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.103",
    "@ai-sdk/react": "^3.0.204",
    "@aws-sdk/client-s3": "^3.1003.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/nextjs": "^9.47.1",
    "@sparticuz/chromium": "^149.0.0",
    "@tanstack/react-query": "^5.59.0",
    "@types/bcryptjs": "^2.4.6",
    "@vidstack/react": "^1.12.13",
    "ai": "^6.0.202",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "hls.js": "^1.5.17",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.11.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.454.0",
    "mammoth": "^1.12.0",
    "next": "^15.5.15",
    "next-auth": "^4.24.10",
    "nodemailer": "^7.0.13",
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.61.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.14.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
