# Neon Postgres — use port 6543 for pooler (required; default 5432 will fail)
DATABASE_URL="postgresql://neondb_owner:PASSWORD@YOUR-NEON-POOLER-HOST:6543/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:PASSWORD@YOUR-NEON-POOLER-HOST:6543/neondb?sslmode=require"

NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="noreply@storytime.com"

# Object storage (S3/R2-compatible) for media uploads
STORAGE_ENDPOINT="https://your-storage-endpoint.example.com" # e.g. https://<account>.r2.cloudflarestorage.com or leave empty for AWS S3
STORAGE_REGION="us-east-1"
STORAGE_BUCKET_NAME="storytime-media"
STORAGE_ACCESS_KEY_ID="your-access-key-id"
STORAGE_SECRET_ACCESS_KEY="your-secret-access-key"
STORAGE_PUBLIC_BASE_URL="https://cdn.example.com/storytime-media"

# ========== MODOC (OpenRouter) — required for AI chat ==========
# 1. Get a key at https://openrouter.ai/keys
# 2. Put it in .env (local) or in your host's env vars (Vercel/Railway/etc.) as OPENROUTER_API_KEY
# 3. For deployment: add OPENROUTER_API_KEY in the hosting dashboard (e.g. Vercel → Project → Settings → Environment Variables)
OPENROUTER_API_KEY="sk-or-v1-YOUR-KEY-HERE"
# Optional: which model MODOC uses (default: openai/gpt-4o-mini). Uncomment to override.
# OPENROUTER_MODOC_MODEL="openai/gpt-4o-mini"
