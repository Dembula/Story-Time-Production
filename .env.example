# Neon Postgres — pooled URL for the app (PgBouncer, port 6543, host includes -pooler)
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-YOUR-ENDPOINT-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"
# Direct URL for Prisma migrations ONLY (no -pooler, port 5432) — required for Vercel builds
DIRECT_URL="postgresql://neondb_owner:PASSWORD@ep-YOUR-ENDPOINT.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Auth (NextAuth)
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# OAuth — social buttons appear only when the matching vars below are set.
# Redirect URI for all providers: {NEXTAUTH_URL}/api/auth/callback/{provider}
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GitHub: Settings → Developer settings → OAuth Apps
GITHUB_ID=""
GITHUB_SECRET=""
# Apple: create a Services ID + Sign in with Apple key, then generate APPLE_SECRET (JWT, ~6 month expiry)
APPLE_ID=""
APPLE_SECRET=""
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="noreply@storytime.com"

# Object storage (S3/R2-compatible) for media uploads
STORAGE_ENDPOINT=""
STORAGE_REGION="us-east-1"
STORAGE_BUCKET_NAME="storytime-media"
STORAGE_ACCESS_KEY_ID="your-access-key-id"
STORAGE_SECRET_ACCESS_KEY="your-secret-access-key"
STORAGE_PUBLIC_BASE_URL="https://cdn.example.com/storytime-media"
UPLOAD_MAX_FILE_SIZE_MB="30720"

# Modoc / OpenRouter (production OS — task-based model routing with fallback)
OPENROUTER_API_KEY="sk-or-v1-YOUR-KEY-HERE"
# OPENROUTER_MODOC_MODEL="openai/gpt-4o-mini"
# Task-based routing (one OPENROUTER_API_KEY — model IDs only, not separate keys):
# OPENROUTER_MODOC_CREATIVE_MODEL="google/gemini-2.5-flash"
# OPENROUTER_MODOC_EXTRACTION_MODEL="google/gemini-2.5-flash"
# OPENROUTER_MODOC_LOGIC_MODEL="openai/gpt-4o-mini"
# OPENROUTER_MODOC_CHAT_MODEL="google/gemini-2.5-flash"
# Note: anthropic/claude-3.5-sonnet is retired on OpenRouter — use claude-sonnet-4.5 or gemini-2.5-flash

# Virtual Assistant — web search (Tavily → Serper → DuckDuckGo fallback)
# VA_WEB_SEARCH_ENABLED="true"
# TAVILY_API_KEY=""
# SERPER_API_KEY=""

# Payments — demo checkout runs automatically until PayFast is configured
# PAYMENTS_DEMO_MODE="true"   # explicit opt-in for demo checkout when PayFast is not configured (never defaults on)
# PAYFAST_MERCHANT_ID=""
# PAYFAST_MERCHANT_KEY=""
# PAYFAST_PASSPHRASE=""  # must exactly match PayFast dashboard (omit if passphrase disabled there)
# NEXT_PUBLIC_BASE_URL="https://story-time.online"  # canonical public URL (not Vercel preview)
# NEXTAUTH_URL="https://story-time.online"
# PAYFAST_NOTIFY_URL="https://story-time.online/api/payments/webhooks/payfast"
# CRON_SECRET=""  # Vercel Cron Authorization: Bearer <CRON_SECRET>

# OpenAI (content enrichment / embeddings / RAG)
OPENAI_API_KEY=""
# Set AI_RAG_ENABLED=false to disable RAG retrieval in MODOC and semantic search
# AI_RAG_ENABLED="true"
# Hybrid recommendations (behavioral + semantic + graph). Set false to use legacy only.
# AI_HYBRID_RECOMMENDATIONS="true"

# AI OS Version 3 — memory cache, A/B models, spoiler gating
# REDIS_URL="redis://localhost:6379"
# Distributed API rate limits (required on multi-instance production)
# Sentry error monitoring
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_ENVIRONMENT="production"
# E2E tests (Playwright)
# E2E_TEST_EMAIL=""
# E2E_TEST_PASSWORD=""
# PLAYWRIGHT_BASE_URL="http://localhost:3000"
# AI_MEMORY_CACHE_ENABLED="true"
# AI_AB_TESTING_ENABLED="true"
# AI_AB_VARIANT_RATIO="50"
# OPENROUTER_AB_DEFAULT_MODEL="google/gemini-2.5-flash"
# OPENROUTER_AB_CHAT_MODEL=""
# OPENROUTER_AB_CREATIVE_MODEL=""
# OPENROUTER_AB_EXTRACTION_MODEL=""
# OPENROUTER_AB_LOGIC_MODEL=""
# AI_SPOILER_PROGRESS_THRESHOLD="0.08"

# South African multilingual AI (11 official languages + slang learning via RAG)
# AI_SA_LANGUAGES_ENABLED="true"
# Run once after deploy: npm run languages:seed-glossary

# Cloudflare Stream (video hosting)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_STREAM_API_TOKEN=""
# CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN="https://customer-xxxxx.cloudflarestream.com"
CLOUDFLARE_STREAM_WEBHOOK_SECRET=""

# Signed playback URLs — set both server + client flags when enabling
CLOUDFLARE_STREAM_SIGNED_URLS="false"
NEXT_PUBLIC_STREAM_SIGNED_URLS="false"

# Offline downloads — web hides these automatically. Native iOS/Android shells enable
# downloads by setting window.__STORYTIME_NATIVE_APP__ = true or using Capacitor.
# Do NOT set NEXT_PUBLIC_NATIVE_OFFLINE_DOWNLOADS on the Vercel web deployment.
# CLOUDFLARE_STREAM_SIGNING_KEY_ID=""
# CLOUDFLARE_STREAM_SIGNING_KEY_JWK=""
# CLOUDFLARE_STREAM_SIGNING_KEY_PEM=""

# Capture protection (standard mode on by default; DRM deferred until encrypted manifests)
# CAPTURE_PROTECTION_ENABLED="true"
# NEXT_PUBLIC_CAPTURE_PROTECTION_ENABLED="true"
# CAPTURE_PROTECTION_MODE="standard"
# NEXT_PUBLIC_CAPTURE_DRM_CONFIGURED="true"
# STORYTIME_DRM_LICENSE_URL=""
# STORYTIME_DRM_AUTH_TOKEN=""

# Email automation (SendGrid)
SENDGRID_API_KEY=""
SENDGRID_TEMPLATE_WELCOME_ID=""
SENDGRID_TEMPLATE_PASSWORD_RESET_ID=""
SENDGRID_TEMPLATE_MONTHLY_UPDATE_ID=""
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
CRON_SECRET=""

# Contract signing uses in-app approval checkboxes (no external e-sign API keys required)

# Receipt vision OCR uses OPENROUTER_API_KEY (see modoc chat) — vision models extract receipt fields from uploaded images
