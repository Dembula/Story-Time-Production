# Neon Postgres — use port 6543 for the pooler
DATABASE_URL="postgresql://neondb_owner:PASSWORD@YOUR-NEON-POOLER-HOST:6543/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:PASSWORD@YOUR-NEON-POOLER-HOST:6543/neondb?sslmode=require"

# Auth (NextAuth)
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# OAuth — social buttons appear only when the matching vars below are set.
# Redirect URI for all providers: {NEXTAUTH_URL}/api/auth/callback/{provider}
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GitHub: Settings → Developer settings → OAuth Apps
GITHUB_ID=""
GITHUB_SECRET=""
# Apple: create a Services ID + Sign in with Apple key, then generate APPLE_SECRET (JWT, ~6 month expiry)
APPLE_ID=""
APPLE_SECRET=""
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="noreply@storytime.com"

# Object storage (S3/R2-compatible) for media uploads
STORAGE_ENDPOINT=""
STORAGE_REGION="us-east-1"
STORAGE_BUCKET_NAME="storytime-media"
STORAGE_ACCESS_KEY_ID="your-access-key-id"
STORAGE_SECRET_ACCESS_KEY="your-secret-access-key"
STORAGE_PUBLIC_BASE_URL="https://cdn.example.com/storytime-media"
UPLOAD_MAX_FILE_SIZE_MB="200"

# Modoc / OpenRouter (production OS — task-based model routing with fallback)
OPENROUTER_API_KEY="sk-or-v1-YOUR-KEY-HERE"
# OPENROUTER_MODOC_MODEL="openai/gpt-4o-mini"
# Task-based routing (one OPENROUTER_API_KEY — model IDs only, not separate keys):
# OPENROUTER_MODOC_CREATIVE_MODEL="anthropic/claude-3.5-sonnet"
# OPENROUTER_MODOC_EXTRACTION_MODEL="google/gemini-2.5-flash"
# OPENROUTER_MODOC_LOGIC_MODEL="openai/gpt-4o"
# OPENROUTER_MODOC_CHAT_MODEL="google/gemini-2.5-flash"

# Payments — demo checkout runs automatically until PayFast is configured
# PAYMENTS_DEMO_MODE="false"  # set to false to block checkout without PayFast
# PAYFAST_MERCHANT_ID=""
# PAYFAST_MERCHANT_KEY=""
# PAYFAST_PASSPHRASE=""

# OpenAI (content enrichment / embeddings)
OPENAI_API_KEY=""

# Cloudflare Stream (video hosting)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_STREAM_API_TOKEN=""
# CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN="https://customer-xxxxx.cloudflarestream.com"
CLOUDFLARE_STREAM_WEBHOOK_SECRET=""

# Signed playback URLs — set both server + client flags when enabling
CLOUDFLARE_STREAM_SIGNED_URLS="false"
NEXT_PUBLIC_STREAM_SIGNED_URLS="false"
# CLOUDFLARE_STREAM_SIGNING_KEY_ID=""
# CLOUDFLARE_STREAM_SIGNING_KEY_JWK=""
# CLOUDFLARE_STREAM_SIGNING_KEY_PEM=""

# Capture protection (standard mode on by default; DRM deferred until encrypted manifests)
# CAPTURE_PROTECTION_ENABLED="true"
# NEXT_PUBLIC_CAPTURE_PROTECTION_ENABLED="true"
# CAPTURE_PROTECTION_MODE="standard"
# NEXT_PUBLIC_CAPTURE_PROTECTION_MODE="standard"
# NEXT_PUBLIC_CAPTURE_DRM_CONFIGURED="true"
# STORYTIME_DRM_LICENSE_URL=""
# STORYTIME_DRM_FAIRPLAY_CERT_URL=""
# STORYTIME_DRM_AUTH_TOKEN=""

# Email automation (SendGrid)
SENDGRID_API_KEY=""
SENDGRID_TEMPLATE_WELCOME_ID=""
SENDGRID_TEMPLATE_PASSWORD_RESET_ID=""
SENDGRID_TEMPLATE_MONTHLY_UPDATE_ID=""
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
CRON_SECRET=""
